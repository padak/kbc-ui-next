# === Single project (simple) ===
# VITE_STACK_URL=https://connection.north-europe.azure.keboola.com
# VITE_STORAGE_TOKEN=your-storage-api-token

# === Multiple projects ===
# JSON array of {stack, token} pairs. All tokens verified on startup.
# VITE_PROJECTS=[{"stack":"https://connection.north-europe.azure.keboola.com","token":"your-token-1"},{"stack":"https://connection.keboola.com","token":"your-token-2"}]

# If both are set, VITE_PROJECTS takes priority over VITE_STACK_URL.
